---
import { getCollection, render } from "astro:content";
import ProseLayout from "../../layouts/ProseLayout.astro";
import { entryPath } from "../../lib/site";

export async function getStaticPaths() {
  const entries = await getCollection("papers", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entryPath(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ProseLayout
  entry={entry}
  sectionLabel="Papers"
  theme="papers"
  headings={headings}
  noteTitle="Reading note"
  noteBody="Paper pages are treated as annotated desk files: the goal is to surface mechanism, assumptions, and what survives close reading."
>
  <Content />
</ProseLayout>
