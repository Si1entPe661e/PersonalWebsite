---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { groupPapersByType } from "../../lib/content";
import { entryHref, entryPath, titleCasePaperType } from "../../lib/site";

export async function getStaticPaths() {
  const entries = await getCollection("papers", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entryPath(entry.id) },
    props: { entry, allEntries: entries },
  }));
}

const { entry, allEntries } = Astro.props;
const { Content, headings } = await render(entry);
const navGroups = groupPapersByType(allEntries).map((group) => ({
  title: group.title,
  items: group.items.map((item) => ({
    href: entryHref("papers", item.id),
    title: item.data.title,
    active: item.id === entry.id,
  })),
}));
---

<DocsLayout
  entry={entry}
  navGroups={navGroups}
  contextLabel={titleCasePaperType(entry.data.paperType, true)}
  sectionLabel="Papers"
  theme="papers"
  headings={headings}
>
  <Content />
</DocsLayout>
