---
import { getCollection, render } from "astro:content";
import ProseLayout from "../../layouts/ProseLayout.astro";
import { entryPath } from "../../lib/site";

export async function getStaticPaths() {
  const entries = await getCollection("essays", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entryPath(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ProseLayout
  entry={entry}
  sectionLabel="Essays"
  theme="essays"
  headings={headings}
  noteTitle="Essay mode"
  noteBody="Essays keep a slower pace: fewer cues, wider margins, and more room for argument to unfold without looking like a notebook entry."
>
  <Content />
</ProseLayout>
