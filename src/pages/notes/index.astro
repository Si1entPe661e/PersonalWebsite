---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHero from "../../components/listing/SectionHero.astro";
import EntryList from "../../components/listing/EntryList.astro";
import { getPublishedCollection, groupNotesBySection } from "../../lib/content";
import { noteSectionHref } from "../../lib/site";

const notes = await getPublishedCollection("notes");
const groups = groupNotesBySection(notes);
---

<BaseLayout title="Notes | Li Zhicheng" description="A small academic library of economics, mathematics, and programming notes." theme="notes" pageKind="index">
  <div class="section-shell section-shell--notes">
    <SectionHero
      eyebrow="Notes"
      title="A compact library for economics, mathematics, and code"
      description="Notes are organized less like a chronological blog and more like shelves in a working library. Each shelf can grow into a longer book-shaped path over time."
    />

    <div class="section-lead section-lead--notes">
      <div class="section-lead__copy">
        <p>The notes pages should feel like shelves in a small study. Each shelf has its own cadence, and entries are meant to be revisited rather than merely consumed once.</p>
      </div>
      <div class="section-lead__aside">
        <span class="kicker">Shelves</span>
        <ul class="section-badges">
          <li><a href={noteSectionHref("economics")}>Economics</a></li>
          <li><a href={noteSectionHref("mathematics")}>Mathematics</a></li>
          <li><a href={noteSectionHref("programming")}>Programming</a></li>
        </ul>
      </div>
    </div>

    <div class="section-grid section-grid--notes">
      {
        groups.map((group) => (
          <section class="section-panel section-panel--shelf">
            <div class="kicker"><a href={noteSectionHref(group.section)}>{group.title}</a></div>
            <EntryList collection="notes" entries={group.items} variant="shelf" />
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
