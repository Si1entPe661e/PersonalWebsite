---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageHref, site } from "../lib/site";

const pages = await getCollection("pages", ({ data }) => !data.draft);
const entry = pages.find((page) => page.id.replace(/\.(md|mdx)$/u, "") === "about");

if (!entry) {
  throw new Error("Missing about page content.");
}

const { Content, headings } = await render(entry);
const sidebarToggleId = "sidebar-toggle-about";
---

<BaseLayout title="About | Li Zhicheng" description={entry.data.description} theme="about" pageKind="page">
  <div class="article-shell">
    <div class="reading-frame">
      <input class="reading-toggle" id={sidebarToggleId} type="checkbox" />
      <div class="reading-frame__bar">
        <label class="reading-toggle__button" for={sidebarToggleId}>
          <span class="reading-toggle__label reading-toggle__label--collapse">Collapse sidebar</span>
          <span class="reading-toggle__label reading-toggle__label--expand">Expand sidebar</span>
        </label>
      </div>

      <div class="article-layout">
      <article class="article-main">
        <header class="article-header">
          <div class="eyebrow">About</div>
          <h1>{entry.data.title}</h1>
          <p class="article-header__description">{entry.data.description}</p>
        </header>
        <div class="prose">
          <Content />
        </div>
      </article>

      <aside class="article-aside">
        <div class="article-panel">
          <h2>Elsewhere</h2>
          <div class="research-links">
            <a href={pageHref("workflow")}>Workflow</a>
            <a href="/research/">Research</a>
            <a href={site.notesUrl}>Notes</a>
            <a href="/rss.xml">RSS</a>
          </div>
        </div>
        {headings.length > 0 && (
          <div class="article-panel">
            <h2>On this page</h2>
            <ol class="toc-list">
              {headings.map((heading) => <li><a href={`#${heading.slug}`}>{heading.text}</a></li>)}
            </ol>
          </div>
        )}
      </aside>
      </div>
    </div>
  </div>
</BaseLayout>
