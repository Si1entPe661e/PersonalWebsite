---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import ProseHeader from "../components/prose/ProseHeader.astro";
import TableOfContents from "../components/prose/TableOfContents.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<"papers"> | CollectionEntry<"essays"> | CollectionEntry<"blog">;
  sectionLabel: string;
  theme: "papers" | "essays" | "blog";
  headings: Heading[];
  noteTitle?: string;
  noteBody?: string;
}

const { entry, sectionLabel, theme, headings, noteTitle, noteBody } = Astro.props;
const sidebarToggleId = `sidebar-toggle-${theme}`;
---

<BaseLayout title={`${entry.data.title} | ${sectionLabel}`} description={entry.data.description} theme={theme} pageKind="detail">
  <div class:list={["article-shell", `article-shell--${theme}`]}>
    <div class="reading-frame">
      <input class="reading-toggle" id={sidebarToggleId} type="checkbox" />
      <div class="reading-frame__bar">
        <label class="reading-toggle__button" for={sidebarToggleId}>
          <span class="reading-toggle__label reading-toggle__label--collapse">Collapse sidebar</span>
          <span class="reading-toggle__label reading-toggle__label--expand">Expand sidebar</span>
        </label>
      </div>

      <div class:list={["article-layout", `article-layout--${theme}`]}>
      <article class="article-main">
        <ProseHeader entry={entry} eyebrow={sectionLabel} />
        <div class="prose">
          <slot />
        </div>
      </article>

      <aside class="article-aside">
        {noteTitle && noteBody && (
          <div class="article-panel article-panel--note">
            <h2>{noteTitle}</h2>
            <p>{noteBody}</p>
          </div>
        )}
        <TableOfContents headings={headings} />
      </aside>
      </div>
    </div>
  </div>
</BaseLayout>
