---
import { isExternalUrl, primaryNav, site } from "../../lib/site";

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href="/" aria-label={`${site.title} homepage`}>
      <span class="site-brand__name">{site.title}</span>
      <span class="site-brand__role">{site.role}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {
        primaryNav.map((item) => (
          <a
            href={item.href}
            data-active={!isExternalUrl(item.href) && (pathname === item.href || pathname.startsWith(item.href.slice(0, -1) + "/"))}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
