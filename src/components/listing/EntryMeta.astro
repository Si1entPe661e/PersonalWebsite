---
import type { CollectionEntry } from "astro:content";
import { formatShortDate } from "../../lib/site";

interface Props {
  entry: CollectionEntry<"research"> | CollectionEntry<"papers"> | CollectionEntry<"notes"> | CollectionEntry<"essays"> | CollectionEntry<"blog">;
}

const { entry } = Astro.props;
---

<div class="entry-meta">
  {entry.data.date && <span>{formatShortDate(entry.data.date)}</span>}
  {entry.data.updated && <span>Updated {formatShortDate(entry.data.updated)}</span>}
  {entry.data.status && <span>{entry.data.status}</span>}
  {"paperType" in entry.data && <span>{entry.data.paperType}</span>}
</div>
